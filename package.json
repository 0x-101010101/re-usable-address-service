{
  "name": "pda-reference-service",
  "version": "1.0.0",
  "description": "Reference implementation for building Persistent Deposit Addresses with One Click API",
  "author": "Defuse Labs",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "NODE_ENV=development nest start --watch",
    "start:prod": "nest build && node dist/main",
    "ui": "pnpm --filter pda-reference-ui dev",
    "dev": "concurrently \"pnpm start\" \"pnpm ui\"",
    "install:all": "pnpm install"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.2",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
